---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Sierra Conditions is a collection of resources useful for getting backcountry information.', image = '/logo.png' } = Astro.props;

const siteUrl = 'https://sierraconditions.com';
const fullImageUrl = `${siteUrl}${image}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    {/* Apply the saved theme synchronously, before CSS parses, to prevent a
        flash of the wrong theme on load. Mirrors the localStorage key used by
        ThemeToggle.astro's SwitchColorMode helper. */}
    <script is:inline>
      (function () {
        try {
          var stored = window.localStorage.getItem('picoPreferredColorScheme');
          var theme = stored && stored !== 'auto' ? stored
            : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          /* localStorage unavailable; let CSS prefers-color-scheme handle it */
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title} - Sierra Conditions</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
  </head>
  <body>
    <slot />

    <script>
      // Mobile menu toggle
      window.addEventListener('load', () => {
        const menuToggle = document.querySelector('#mobile-menu-toggle');
        const sidebar = document.querySelector('.site-sidebar');
        if (menuToggle && sidebar) {
          menuToggle.addEventListener('click', () => {
            sidebar.classList.toggle('open');
          });
        }
      });
    </script>
  </body>
</html>
